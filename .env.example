# Supabase — copie para .env.local e preencha com seus valores
# Encontre em: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui

# IA (Claude Vision) — captura de transação por foto
# ⚠️ ATENÇÃO: usar a chave no frontend a EXPÕE publicamente. Use só para teste.
# Crie em: https://console.anthropic.com → API Keys
VITE_ANTHROPIC_API_KEY=sk-ant-...
# opcional: modelo (default: claude-haiku-4-5-20251001 — barato e lê imagens)
VITE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
